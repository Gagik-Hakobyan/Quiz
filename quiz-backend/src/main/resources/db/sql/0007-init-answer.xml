<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="0007-init-answer" author="ghakobyan">
        <createTable tableName="answer">
            <column name="id" type="bigserial">
                <constraints primaryKey="true"/>
            </column>

            <column name="selected_option_id" type="bigint">
                <constraints
                        foreignKeyName="fk_answer_option"
                        referencedTableName="option"
                        referencedColumnNames="id"/>
            </column>

            <column name="question_id" type="bigint">
                <constraints
                        foreignKeyName="fk_answer_question"
                        referencedTableName="question"
                        referencedColumnNames="id"
                        nullable="false"/>
            </column>

            <column name="attempt_id" type="bigint">
                <constraints
                        foreignKeyName="fk_answer_attempt"
                        referencedTableName="attempt"
                        referencedColumnNames="id"
                        nullable="false"/>
            </column>

            <column name="text_answer" type="text"/>

            <column name="points" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>