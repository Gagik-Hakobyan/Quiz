<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="0005-init-attempt" author="ghakobyan">
        <createTable tableName="attempt">
            <column name="id" type="bigserial">
                <constraints primaryKey="true"/>
            </column>

            <column name="user_id" type="bigint">
                <constraints
                        foreignKeyName="fk_attempt_user"
                        referencedTableName="users"
                        referencedColumnNames="id"
                        nullable="false"/>
            </column>

            <column name="quiz_id" type="bigint">
                <constraints
                        foreignKeyName="fk_attempt_quiz"
                        referencedTableName="quiz"
                        referencedColumnNames="id"
                        nullable="false"/>
            </column>


            <column name="status" type="varchar(20)" defaultValue="IN_PROGRESS">
                <constraints nullable="false"/>
            </column>

            <column name="max_points" type="int">
                <constraints nullable="false"/>
            </column>

            <column name="current_points" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>


            <column name="started_date" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>

            <column name="ended_date" type="timestamp"/>
        </createTable>
    </changeSet>

</databaseChangeLog>